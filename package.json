{
  "name": "mcp-immo-france",
  "version": "0.1.0",
  "description": "MCP server for French real-estate intelligence: real sale prices (DVF), price per m², energy ratings (DPE), natural risks and commune data for any French address. Zero API keys.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcp-immo-france": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "immobilier",
    "france",
    "dvf",
    "dpe",
    "georisques",
    "real-estate",
    "open-data",
    "ban",
    "adresse"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeddparis/mcp-immo-france.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
